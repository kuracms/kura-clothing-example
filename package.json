{
  "name": "kura-clothing-example",
  "version": "0.1.0",
  "private": true,
  "description": "Example SvelteKit site reading from a kura content backend. A small British clothing label demo at clothing.kuracms.com.",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "deploy": "vite build && wrangler deploy"
  },
  "devDependencies": {
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.61.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "svelte": "^5.46.0",
    "svelte-check": "^4.0.0",
    "tslib": "^2.7.0",
    "typescript": "^5.6.0",
    "vite": "^7.3.0",
    "wrangler": "^4.93.1"
  },
  "dependencies": {
    "marked": "^14.1.0"
  }
}
